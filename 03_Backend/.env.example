# =============================================================================
# CSM-GIAS Resto+ — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# NEVER commit .env to version control.
# =============================================================================

# --- Application ---
APP_NAME="CSM-GIAS Resto+"
APP_VERSION="1.0.0"
APP_DEBUG=false
# Valid values: development | testing | production
APP_ENVIRONMENT=development
APP_SECRET_KEY=change-me-to-a-random-64-char-string

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=4
SERVER_MAX_REQUESTS=1000
SERVER_TIMEOUT_KEEPALIVE=5

# --- Database (MySQL via Docker) ---
# The Docker MySQL container is configured in docker-compose.yml.
# Local development uses port 3307 to avoid conflicts with a
# potential local MySQL on the default port 3306.
DB_HOST=localhost
DB_PORT=3307
DB_USER=resto_user
DB_PASSWORD=change-me
DB_NAME=resto_plus
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO_SQL=false

# --- Authentication ---
JWT_SECRET_KEY=change-me-to-another-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# --- Tablet ---
TABLET_API_KEY=change-me-to-tablet-api-key

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=logs/app.log
LOG_ROTATION=1 day
LOG_RETENTION=30 days

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# --- Email ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@csm-gias.resto
SMTP_STARTTLS=true

# --- Timezone ---
TZ=Africa/Casablanca
